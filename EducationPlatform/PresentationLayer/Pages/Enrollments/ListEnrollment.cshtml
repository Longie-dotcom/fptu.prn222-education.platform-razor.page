@page
@model PresentationLayer.Pages.Enrollments.ListEnrollmentModel
@using Domain.EnrollmentManagement.Enum
@{
    ViewBag.Title = "My Learning";

    // Helper for enrollment status badges
    (string bg, string text, string label) GetEnrollmentStatus(EnrollmentStatus status)
    {
        return status switch
        {
            EnrollmentStatus.Completed => ("#f0fdf4", "#16a34a", "Completed"),
            EnrollmentStatus.Active => ("#eff6ff", "#2563eb", "In Progress"),
            _ => ("#f1f5f9", "#475569", status.ToString())
        };
    }
}

<div style="margin: 0 auto; padding: 30px 20px; font-family: 'Segoe UI', Arial, sans-serif; max-width: 1300px;">

    @* Header Section *@
    <div style="margin-bottom: 40px; display: flex; justify-content: space-between; align-items: flex-end;">
        <div>
            <h2 style="color: #2d3436; font-weight: 800; font-size: 2.2rem; margin: 0;">My Learning</h2>
            <p style="color: #636e72; margin-top: 5px; font-size: 1.1rem;">Continue where you left off and master new skills.</p>
        </div>
        <a asp-page="/Courses/ListCourse"
           style="text-decoration: none; background: #4834d4; color: white; padding: 12px 24px; border-radius: 10px; font-weight: 700; transition: 0.3s; box-shadow: 0 4px 12px rgba(72, 52, 212, 0.2);"
           onmouseover="this.style.transform='translateY(-2px)'; this.style.boxShadow='0 6px 15px rgba(72, 52, 212, 0.3)';"
           onmouseout="this.style.transform='translateY(0)';">
            Explore More Courses
        </a>
    </div>

    @if (Model.Enrollments.Any())
    {
        <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(380px, 1fr)); gap: 30px;">
            @foreach (var enrollment in Model.Enrollments)
            {
                var statusInfo = GetEnrollmentStatus(enrollment.Status);
                // Handle decimal to percentage string
                var progressPercent = enrollment.CourseProgress?.CompletionRate ?? 0;

                <div style="background: white; border-radius: 16px; overflow: hidden; border: 1px solid #eee; box-shadow: 0 4px 20px rgba(0,0,0,0.04); transition: all 0.3s ease; display: flex; flex-direction: column;"
                     onmouseover="this.style.transform='translateY(-10px)'; this.style.boxShadow='0 15px 30px rgba(0,0,0,0.1)'; this.style.borderColor='#4834d4';"
                     onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='0 4px 20px rgba(0,0,0,0.04)'; this.style.borderColor='#eee';">

                    @* Image & Overlay Status *@
                    <div style="height: 180px; position: relative; overflow: hidden;">
                        @if (!string.IsNullOrEmpty(enrollment.Course?.ThumbnailName))
                        {
                            <img src="~/media/@enrollment.Course.ThumbnailName" style="width: 100%; height: 100%; object-fit: cover;" alt="Course Thumbnail" />
                        }
                        else
                        {
                            <div style="width: 100%; height: 100%; background: #f1f2f6; display: flex; align-items: center; justify-content: center; color: #ced6e0;">
                                <span style="font-size: 3rem;">📖</span>
                            </div>
                        }
                        <div style="position: absolute; top: 15px; right: 15px; background: @statusInfo.bg; color: @statusInfo.text; padding: 5px 12px; border-radius: 8px; font-size: 0.75rem; font-weight: 800; border: 1px solid @statusInfo.text; backdrop-filter: blur(8px);">
                            @statusInfo.label
                        </div>
                    </div>

                    @* Content *@
                    <div style="padding: 25px; flex-grow: 1; display: flex; flex-direction: column;">
                        <div style="display: flex; gap: 8px; margin-bottom: 12px;">
                            <span style="font-size: 0.65rem; background: #f3f0ff; color: #7048e8; padding: 4px 8px; border-radius: 4px; font-weight: 800; text-transform: uppercase;">@enrollment.Course?.Subject?.Name</span>
                            <span style="font-size: 0.65rem; background: #f8f9fa; color: #495057; padding: 4px 8px; border-radius: 4px; font-weight: 800; text-transform: uppercase;">@enrollment.Course?.Grade?.Name</span>
                        </div>

                        <h3 style="margin: 0 0 10px 0; color: #2d3436; font-size: 1.25rem; line-height: 1.4; font-weight: 700; min-height: 3.5rem;">
                            @enrollment.Course?.Title
                        </h3>

                        @* Progress Section *@
                        <div style="margin: 20px 0;">
                            <div style="display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 8px;">
                                <span style="color: #636e72; font-size: 0.85rem; font-weight: 600;">Overall Progress</span>
                                <span style="color: #4834d4; font-size: 1rem; font-weight: 800;">@progressPercent%</span>
                            </div>
                            <div style="width: 100%; height: 10px; background: #f1f2f6; border-radius: 20px; overflow: hidden;">
                                <div style="width: @progressPercent%; height: 100%; background: linear-gradient(90deg, #4834d4, #686de0); border-radius: 20px; transition: width 1s cubic-bezier(0.22, 1, 0.36, 1);"></div>
                            </div>
                        </div>

                        @* Footer Action *@
                        <div style="margin-top: auto; padding-top: 20px; border-top: 1px solid #f1f2f6; display: flex; justify-content: space-between; align-items: center;">
                            <div style="display: flex; flex-direction: column;">
                                <span style="font-size: 0.7rem; color: #b2bec3; text-transform: uppercase; font-weight: 700;">Joined On</span>
                                <span style="font-size: 0.9rem; color: #2d3436; font-weight: 600;">@enrollment.EnrolledAt.ToString("MMM dd, yyyy")</span>
                            </div>

                            <a asp-page="/Enrollments/ResumeLearning"
                               asp-route-enrollmentId="@enrollment.EnrollmentID"
                               style="text-decoration: none; background: #f8f9fa; color: #2d3436; padding: 10px 20px; border-radius: 8px; font-weight: 700; font-size: 0.85rem; border: 1px solid #dfe6e9; transition: 0.2s;"
                               onmouseover="this.style.background='#4834d4'; this.style.color='white'; this.style.borderColor='#4834d4';"
                               onmouseout="this.style.background='#f8f9fa'; this.style.color='#2d3436'; this.style.borderColor='#dfe6e9';">
                                Resume Course
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        @* Empty State *@
        <div style="text-align: center; padding: 100px 20px; background: white; border-radius: 20px; border: 2px dashed #dfe6e9; margin-top: 20px;">
            <div style="font-size: 4rem; margin-bottom: 20px;">🚀</div>
            <h2 style="color: #2d3436; margin-bottom: 10px;">Your learning shelf is empty</h2>
            <p style="color: #636e72; max-width: 400px; margin: 0 auto 30px auto; line-height: 1.6;">
                You haven't enrolled in any courses yet. Start exploring our catalog to begin your journey.
            </p>
            <a asp-page="/Courses/ListCourse"
               style="text-decoration: none; background: #4834d4; color: white; padding: 15px 40px; border-radius: 12px; font-weight: 700; display: inline-block; transition: 0.3s;">
                Find a Course
            </a>
        </div>
    }
</div>