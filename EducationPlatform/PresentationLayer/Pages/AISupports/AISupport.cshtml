@page
@model PresentationLayer.Pages.AISupports.AISupportModel
@{
    ViewData["Title"] = "AI Learning Support";
    var primaryColor = "#4834d4";
}

<div style="max-width: 1000px; margin: 40px auto; font-family: 'Segoe UI', sans-serif; padding: 0 20px;">

    @* Header Section *@
    <div style="display: flex; align-items: center; gap: 20px; margin-bottom: 40px; background: white; padding: 30px; border-radius: 15px; box-shadow: 0 4px 15px rgba(0,0,0,0.05);">
        <div style="font-size: 3rem;">🤖</div>
        <div>
            <h2 style="margin: 0; color: #2d3436;">Personalized AI Tutor</h2>
            <p style="margin: 5px 0 0; color: #636e72;">I've analyzed your progress. Let's strengthen the areas where you've struggled.</p>
        </div>
    </div>

    <div style="display: grid; grid-template-columns: 1fr 350px; gap: 30px;">

        @* Left Column: Quiz Area *@
        <div>
            @if (string.IsNullOrEmpty(Model.GeneratedQuiz))
            {
                @* Default Empty State *@
                <div id="quizPlaceholder" style="background: white; border: 2px dashed #dfe6e9; border-radius: 12px; padding: 60px; text-align: center; color: #b2bec3;">
                    <div style="font-size: 3rem; margin-bottom: 15px;">📝</div>
                    <h3>Ready to practice?</h3>
                    <p>Click the "Generate Personalized Quiz" button to start.</p>
                </div>
            }

            @* Loading Skeleton (Hidden by default, shown via JS) *@
            <div id="quizSkeleton" style="display: none; background: white; padding: 30px; border-radius: 12px; box-shadow: 0 10px 30px rgba(0,0,0,0.08);">
                <div class="skeleton skeleton-title"></div>
                <div style="margin-bottom: 30px; padding: 20px; border: 1px solid #edf2f7; border-radius: 10px;">
                    <div class="skeleton skeleton-text" style="width: 80%;"></div>
                    <div class="skeleton skeleton-option"></div>
                    <div class="skeleton skeleton-option"></div>
                    <div class="skeleton skeleton-option"></div>
                </div>
                <div style="padding: 20px; border: 1px solid #edf2f7; border-radius: 10px;">
                    <div class="skeleton skeleton-text" style="width: 70%;"></div>
                    <div class="skeleton skeleton-option"></div>
                    <div class="skeleton skeleton-option"></div>
                </div>
            </div>

            @if (!string.IsNullOrEmpty(Model.GeneratedQuiz))
            {
                @* Actual Quiz Container *@
                <div id="aiQuizContainer" style="background: white; padding: 30px; border-radius: 12px; box-shadow: 0 10px 30px rgba(0,0,0,0.08);">
                    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 25px; border-bottom: 2px solid #f1f2f6; padding-bottom: 15px;">
                        <h3 style="margin: 0;">AI Generated Practice</h3>
                        <span style="background: #e1eeff; color: #4834d4; padding: 5px 12px; border-radius: 20px; font-size: 0.8rem; font-weight: bold;">
                            Mistral-7B-Instruct-v0.2
                        </span>
                    </div>
                    <div id="quizContent"></div>
                </div>
            }
        </div>

        @* Right Column: Weakness List *@
        <div style="background: #fff; padding: 25px; border-radius: 12px; align-self: start; border: 1px solid #eee;">
            <h4 style="margin-top: 0; color: #2d3436; border-bottom: 1px solid #eee; padding-bottom: 10px;">Identified Weak Topics</h4>

            @if (!Model.Weaknesses.Any())
            {
                <p style="color: #16a34a; font-size: 0.9rem;">✨ Great job! No significant weaknesses detected yet.</p>
            }
            else
            {
                @foreach (var item in Model.Weaknesses)
                {
                    <div style="margin-bottom: 15px; padding-bottom: 15px; border-bottom: 1px solid #f8f9fa;">
                        <div style="font-weight: bold; font-size: 0.9rem; color: #2d3436;">@item.LessonTitle</div>
                        <div style="font-size: 0.75rem; color: #636e72;">@item.CourseTitle</div>
                        <div style="display: flex; justify-content: space-between; margin-top: 8px;">
                            <span style="color: #eb4d4b; font-size: 0.75rem; font-weight: 700;">@item.FailedQuizCount failed attempts</span>
                            <span style="color: @primaryColor; font-size: 0.75rem;">@item.CompletionRate% Lesson Score</span>
                        </div>
                    </div>
                }
            }

            <form method="post" asp-page-handler="GenerateQuiz" onsubmit="showLoading()">
                <button type="submit" id="generateBtn" style="width: 100%; margin-top: 10px; background: @primaryColor; color: white; border: none; padding: 12px; border-radius: 8px; font-weight: bold; cursor: pointer; transition: 0.3s;">
                    Generate Personalized Quiz
                </button>
            </form>
        </div>
    </div>
</div>

@* Hidden Input to pass AI JSON to JS *@
<script>
    const rawAiJson = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.GeneratedQuiz));
</script>
<style>
    .skeleton {
        background: #eee;
        background: linear-gradient(110deg, #ececec 8%, #f5f5f5 18%, #ececec 33%);
        border-radius: 5px;
        background-size: 200% 100%;
        animation: 1.5s shine linear infinite;
    }

    @@keyframes shine {
        to {
            background-position-x: -200%;
        }
    }

    .skeleton-text {
        height: 1.2rem;
        margin-bottom: 0.5rem;
        width: 100%;
    }

    .skeleton-title {
        height: 2rem;
        margin-bottom: 1.5rem;
        width: 60%;
    }

    .skeleton-option {
        height: 3rem;
        margin-bottom: 0.8rem;
        border-radius: 8px;
    }
</style>

<script>
    document.addEventListener("DOMContentLoaded", function() {
        if (!rawAiJson) return;

        const rawJson = rawAiJson;

        try {

            let cleanJson = rawJson
                .replace(/```json/g, "")
                .replace(/```/g, "")
                .trim();

            const start = cleanJson.indexOf('[');
            const end = cleanJson.lastIndexOf(']');

            if (start !== -1 && end !== -1) {
                cleanJson = cleanJson.substring(start, end + 1);
            }

            const quizData = JSON.parse(cleanJson);

            renderAiQuiz(quizData);

        } catch (e) {
            console.error("AI Parsing Error:", rawJson);
            document.getElementById('quizContent').innerHTML =
                `<div class="alert alert-danger">AI returned invalid format. Please regenerate.</div>`;
        }
    });

    function renderAiQuiz(data) {
        const container = document.getElementById('quizContent');
        let html = '';

        // Expecting an array of questions based on your prompt
        const questions = Array.isArray(data) ? data : (data.questions || []);

        questions.forEach((q, index) => {
            html += `
                <div style="margin-bottom: 30px; padding: 20px; background: #fdfdfd; border: 1px solid #edf2f7; border-radius: 10px;">
                    <p style="font-weight: bold; color: #2d3436; margin-bottom: 15px;">Q${index + 1}: ${q.question || q.text}</p>
                    <div style="display: grid; gap: 10px;">
                        ${(q.options || []).map(opt => `
                            <label style="display: flex; align-items: center; gap: 10px; padding: 10px; border: 1px solid #e2e8f0; border-radius: 6px; cursor: pointer; background: white;">
                                <input type="radio" name="ai_q_${index}" value="${opt}">
                                <span style="font-size: 0.9rem;">${opt}</span>
                            </label>
                        `).join('')}
                    </div>
                    <button onclick="toggleAiExplanation(${index})" style="margin-top: 15px; background: none; border: none; color: #4834d4; font-size: 0.8rem; cursor: pointer; text-decoration: underline;">
                        Check Answer
                    </button>
                    <div id="ai_exp_${index}" style="display:none; margin-top: 15px; padding: 15px; background: #f0f7ff; border-left: 4px solid #4834d4; border-radius: 4px; font-size: 0.9rem;">
                        <strong>Correct Answer:</strong> ${q.correct_answer || q.answer}<br/>
                        <strong>Explanation:</strong> ${q.explanation}
                    </div>
                </div>
            `;
        });

        container.innerHTML = html;
    }

    function toggleAiExplanation(index) {
        const el = document.getElementById(`ai_exp_${index}`);
        el.style.display = el.style.display === 'none' ? 'block' : 'none';
    }

    function showLoading() {
        // Hide the placeholder or the previous quiz
        const placeholder = document.getElementById('quizPlaceholder');
        const quizContainer = document.getElementById('aiQuizContainer');
        const btn = document.getElementById('generateBtn');

        if(placeholder) placeholder.style.display = 'none';
        if(quizContainer) quizContainer.style.display = 'none';

        // Show the skeleton
        document.getElementById('quizSkeleton').style.display = 'block';

        // Disable button to prevent double clicks
        btn.disabled = true;
        btn.style.opacity = '0.7';
        btn.innerText = 'Generating with AI...';
    }
</script>