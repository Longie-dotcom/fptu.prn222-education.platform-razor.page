@page
@model PresentationLayer.Pages.Orders.ListOrderModel
@using BusinessLayer.DTO
@using Domain.OrderManagement.Enum
@{
    ViewBag.Title = "Order Management";
    var primaryColor = "#4834d4";
}

<div style="max-width: 1100px; margin: 0 auto; padding: 20px; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; padding-bottom: 100px;">

    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px;">
        <div>
            <h2 style="color: #2d3436; font-weight: 700; margin: 0;">Order History</h2>
            <p style="color: #636e72; margin-top: 5px;">Manage and track all transaction records</p>
        </div>

        <div style="display: flex; gap: 10px; background: #f1f5f9; padding: 5px; border-radius: 10px;">
            <a asp-page="/Orders/ListOrder" asp-route-status=""
               style="text-decoration: none; padding: 8px 16px; border-radius: 8px; font-size: 0.85rem; font-weight: 600;
               @(string.IsNullOrEmpty(Model.Status)
                       ? $"background:white; color:{primaryColor}; box-shadow:0 2px 5px rgba(0,0,0,0.05);"
                       : "color:#64748b;")">
                All
            </a>

            <a asp-page="/Orders/ListOrder" asp-route-status="PAID"
               style="text-decoration: none; padding: 8px 16px; border-radius: 8px; font-size: 0.85rem; font-weight: 600;
               @(Model.Status == "PAID"
                       ? $"background:white; color:{primaryColor}; box-shadow:0 2px 5px rgba(0,0,0,0.05);"
                       : "color:#64748b;")">
                Pending
            </a>

            <a asp-page="/Orders/ListOrder" asp-route-status="PENDING"
               style="text-decoration: none; padding: 8px 16px; border-radius: 8px; font-size: 0.85rem; font-weight: 600;
               @(Model.Status == "PENDING"
                       ? $"background:white; color:{primaryColor}; box-shadow:0 2px 5px rgba(0,0,0,0.05);"
                       : "color:#64748b;")">
                Processing
            </a>
        </div>
    </div>

    @if (Model.Orders == null || !Model.Orders.Any())
    {
        <div style="background: white; padding: 80px; border-radius: 15px; box-shadow: 0 4px 20px rgba(0,0,0,0.08); text-align: center;">
            <i class="bi bi-receipt-cutoff" style="font-size: 50px; color: #cbd5e0;"></i>
            <p style="color: #718096; margin-top: 20px; font-size: 1.1rem;">No orders found matching your criteria.</p>
        </div>
    }
    else
    {
        <div style="background: white; border-radius: 15px; box-shadow: 0 4px 20px rgba(0,0,0,0.08); overflow: hidden;">
            <table style="width: 100%; border-collapse: collapse; text-align: left;">
                <thead>
                    <tr style="text-align: left; border-bottom: 2px solid #edf2f7;">
                        <th style="padding: 20px; color: #b2bec3; font-size: 0.8rem; text-transform: uppercase;">Order Code</th>
                        <th style="padding: 20px; color: #b2bec3; font-size: 0.8rem; text-transform: uppercase;">Date</th>
                        <th style="padding: 20px; color: #b2bec3; font-size: 0.8rem; text-transform: uppercase;">Earnings</th>
                        <th style="padding: 20px; color: #b2bec3; font-size: 0.8rem; text-transform: uppercase;">Fee</th>
                        <th style="padding: 20px; color: #b2bec3; font-size: 0.8rem; text-transform: uppercase;">Status</th>
                        <th style="padding: 20px; color: #b2bec3; font-size: 0.8rem; text-transform: uppercase; text-align: center;">Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var order in Model.Orders)
                    {
                        string label;
                        string statusBg;
                        string statusText;

                        if (order.Status == OrderStatus.Paid)
                        {
                            label = "Pending";
                            statusBg = "#fff9e6";
                            statusText = "#f1c40f";
                        }
                        else if (order.Status == OrderStatus.Pending)
                        {
                            label = "Processing";
                            statusBg = "#e8f5ff";
                            statusText = "#0984e3";
                        }
                        else if (order.Status == OrderStatus.Failed)
                        {
                            label = "Failed";
                            statusBg = "#fff0f0";
                            statusText = "#d63031";
                        }
                        else
                        {
                            label = order.Status.ToString();
                            statusBg = "#f1f2f6";
                            statusText = "#636e72";
                        }

                        // Calculation for total if needed for a "Total" column,
                        // otherwise we just show the split amounts.
                        var totalAmount = order.PlatformAmount + order.TeacherAmount;

                        <tr style="border-bottom: 1px solid #edf2f7; transition: background 0.2s;" onmouseover="this.style.background='#fcfdff'" onmouseout="this.style.background='white'">
                            <td style="padding: 20px; font-weight: 600; color: #2d3436;">#@order.OrderCode</td>

                            <td style="padding: 20px; color: #636e72; font-size: 0.9rem;">
                                @order.CreatedAt.ToString("dd/MM/yyyy HH:mm")
                            </td>

                            @* SEPARATED TEACHER AMOUNT *@
                            <td style="padding: 20px; color: #2d3436;">
                                <div style="font-weight: 700;">@order.TeacherAmount.ToString("N0")đ</div>
                                <div style="font-size: 0.7rem; color: #b2bec3; text-transform: uppercase;">Teacher Earn</div>
                            </td>

                            @* SEPARATED COMMISSION (PLATFORM) AMOUNT *@
                            <td style="padding: 20px; color: #636e72;">
                                <div style="font-weight: 600;">@order.PlatformAmount.ToString("N0")đ</div>
                                <div style="font-size: 0.7rem; color: #b2bec3; text-transform: uppercase;">Commission</div>
                            </td>

                            <td style="padding: 20px;">
                                <span style="background: @statusBg; color: @statusText; padding: 6px 12px; border-radius: 6px; font-size: 0.75rem; font-weight: 800; text-transform: uppercase;">
                                    @label
                                </span>
                            </td>

                            <td style="padding: 20px; text-align: center;">
                                <a asp-page="/Courses/CourseDetail" asp-route-id="@order.CourseID"
                                   style="text-decoration: none; border: 1px solid @primaryColor; color: @primaryColor; padding: 6px 14px; border-radius: 6px; font-weight: 600; font-size: 0.8rem; transition: all 0.2s;"
                                   onmouseover="this.style.backgroundColor='@primaryColor'; this.style.color='white';"
                                   onmouseout="this.style.backgroundColor='transparent'; this.style.color='@primaryColor';">
                                    View Course
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">