@page
@model PresentationLayer.Pages.Orders.ReturnOrderModel
@{
    ViewBag.Title = "Payment Status";
    var primaryColor = "#4834d4";
    var successColor = "#00b894";
    var dangerColor = "#d63031";
    var statusColor = Model.VM.IsSuccess ? successColor : dangerColor;
}

<div style="max-width: 800px; margin: 0 auto; padding: 40px 20px; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; min-height: 80vh;">

    <div style="background: white; padding: 50px 30px; border-radius: 15px; box-shadow: 0 4px 20px rgba(0,0,0,0.08); text-align: center;">

        <h2 style="color: #2d3436; font-weight: 700; margin-bottom: 15px; font-size: 2rem;">
            @(Model.VM.IsSuccess ? "Payment Successful" : "Payment Incomplete")
        </h2>

        <p style="color: #636e72; font-size: 1.1rem; line-height: 1.6; max-width: 500px; margin: 0 auto 30px auto;">
            @Model.VM.Message
        </p>

        <div style="background: #f8fafc; padding: 20px; border-radius: 12px; border: 1px solid #e2e8f0; display: inline-block; min-width: 300px; margin-bottom: 40px;">
            <div style="font-size: 0.85rem; font-weight: 700; color: #b2bec3; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 5px;">
                Transaction Reference
            </div>
            <div style="font-size: 1.25rem; font-weight: 700; color: #2d3436;">
                #@Model.VM.OrderCode
            </div>
            <div style="margin-top: 10px; font-size: 0.9rem; color: #718096;">
                Status: <span style="font-weight: 600; color: @statusColor;">@Model.VM.Status</span>
            </div>
        </div>

        <div style="display: flex; flex-direction: column; gap: 15px; align-items: center; max-width: 400px; margin: 0 auto;">

            @if (Model.VM.IsSuccess)
            {
                <a asp-page="/Enrollments/ListEnrollment"
                   style="text-decoration: none; border: 1px solid #4834d4; color: #4834d4; width: 100%; padding: 12px; border-radius: 6px; font-weight: 600; font-size: 0.9rem; transition: all 0.2s; cursor: pointer; display: inline-block;"
                   onmouseover="this.style.backgroundColor='#4834d4'; this.style.color='white';"
                   onmouseout="this.style.backgroundColor='transparent'; this.style.color='#4834d4';">
                    View My Enrollments
                </a>
            }
            else
            {
                <a asp-page="/Courses/ListCourse"
                   style="text-decoration: none; border: 1px solid #d63031; color: #d63031; width: 100%; padding: 12px; border-radius: 6px; font-weight: 600; font-size: 0.9rem; transition: all 0.2s; cursor: pointer; display: inline-block;"
                   onmouseover="this.style.backgroundColor='#d63031'; this.style.color='white';"
                   onmouseout="this.style.backgroundColor='transparent'; this.style.color='#d63031';">
                    Try Again
                </a>
            }

            <a asp-page="/Courses/ListCourse"
               style="text-decoration: none; border: 1px solid #4834d4; color: #4834d4; width: 100%; padding: 12px; border-radius: 6px; font-weight: 600; font-size: 0.9rem; transition: all 0.2s; cursor: pointer; display: inline-block;"
               onmouseover="this.style.backgroundColor='#4834d4'; this.style.color='white';"
               onmouseout="this.style.backgroundColor='transparent'; this.style.color='#4834d4';">
                Back to Course List
            </a>
        </div>
    </div>
</div>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">