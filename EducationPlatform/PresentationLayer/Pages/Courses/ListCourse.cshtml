@page
@model PresentationLayer.Pages.Courses.ListCourseModel
@using System.Security.Claims
@using Domain.CourseManagement.Enum
@{
    ViewData["Title"] = "Explore Courses";
    var userRole = User.FindFirst(ClaimTypes.Role)?.Value ?? "";

    // Helper function for status badges
    (string bg, string text, string label) GetStatusDetails(string statusStr)
    {
        if (Enum.TryParse<CourseStatus>(statusStr, out var statusEnum))
        {
            return statusEnum switch
            {
                CourseStatus.Published => ("#f0fdf4", "#16a34a", "Published"),
                CourseStatus.InReview => ("#fffbeb", "#d97706", "In Review"),
                CourseStatus.Rejected => ("#fef2f2", "#dc2626", "Rejected"),
                _ => ("#f1f5f9", "#475569", statusStr)
            };
        }
        return ("#f1f5f9", "#475569", statusStr);
    }
}

<div style="margin: 0 auto; padding: 30px 20px; font-family: 'Segoe UI', Arial, sans-serif;">

    @* Page Heading *@
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px; gap: 20px;">

        <div>
            <h2 style="color: #2d3436; font-weight: 800; font-size: 2rem; margin: 0;">Explore Catalog</h2>
            <p style="color: #636e72; margin-top: 5px; margin-bottom: 0;">Normalized course data for Grades and Subjects</p>
        </div>

        <div>
            @if (userRole == "Teacher" || userRole == "2")
            {
                <a asp-page="CreateCourse"
                    style="display: inline-block; text-decoration: none; border: 1px solid #4834d4; color: #4834d4; padding: 10px 20px; border-radius: 6px; font-weight: 600; font-size: 0.9rem; transition: all 0.2s; white-space: nowrap;"
                   onmouseover="this.style.backgroundColor='#4834d4'; this.style.color='white';"
                   onmouseout="this.style.backgroundColor='transparent'; this.style.color='#4834d4';">
                    <span>+ Create Course</span>
                </a>
            }
        </div>

    </div>

    <div style="display: grid; grid-template-columns: 280px 1fr; gap: 30px;">

        @* LEFT: FILTER SIDEBAR *@
        <aside>
            <form method="get"
                style="background: white; padding: 25px; border-radius: 12px; box-shadow: 0 4px 15px rgba(0,0,0,0.05); position: sticky; top: 20px; border: 1px solid #eee;">

                <h4 style="margin-top: 0; margin-bottom: 20px; font-size: 1.1rem; color: #2d3436;">Filters</h4>

                @* Search Title *@
                <div style="margin-bottom: 18px;">
                    <label style="display: block; font-size: 0.75rem; font-weight: 700; color: #b2bec3; margin-bottom: 8px; text-transform: uppercase;">Search Title</label>
                    <input type="text" name="title" placeholder="Course name" value="@Model.VM.Title"
                           style="width: 100%; padding: 12px; border: 1px solid #dfe6e9; border-radius: 8px; outline: none; box-sizing: border-box;"
                           onfocus="this.style.borderColor='#4834d4'" onblur="this.style.borderColor='#dfe6e9'" />
                </div>

                @* Grade Level *@
                <div style="margin-bottom: 18px;">
                    <label style="display: block; font-size: 0.75rem; font-weight: 700; color: #b2bec3; margin-bottom: 8px; text-transform: uppercase;">Grade Level</label>
                    <select name="gradeName" style="width: 100%; padding: 12px; border: 1px solid #dfe6e9; border-radius: 8px; outline: none; box-sizing: border-box;"
                            onfocus="this.style.borderColor='#4834d4'" onblur="this.style.borderColor='#dfe6e9'">
                        <option value="">All Grades</option>
                        @foreach (var g in Model.VM.Grades)
                        {
                            <!option value="@g.Name" @(Model.VM.GradeName == g.Name ? "selected" : "")>@g.Name</!option>
                        }
                    </select>
                </div>

                @* Subject *@
                <div style="margin-bottom: 25px;">
                    <label style="display: block; font-size: 0.75rem; font-weight: 700; color: #b2bec3; margin-bottom: 8px; text-transform: uppercase;">Subject</label>
                    <select name="subjectName" style="width: 100%; padding: 12px; border: 1px solid #dfe6e9; border-radius: 8px; outline: none; box-sizing: border-box;"
                            onfocus="this.style.borderColor='#4834d4'" onblur="this.style.borderColor='#dfe6e9'">
                        <option value="">All Subjects</option>
                        @foreach (var s in Model.VM.Subjects)
                        {
                            <!option value="@s.Name" @(Model.VM.SubjectName == s.Name ? "selected" : "")>@s.Name</!option>
                        }
                    </select>
                </div>

                <button type="submit" style="width: 100%; background: #4834d4; color: white; border: none; padding: 12px; border-radius: 8px; font-weight: 700; cursor: pointer; transition: 0.2s;"
                        onmouseover="this.style.background='#3c2bb3'" onmouseout="this.style.background='#4834d4'">
                    Apply Filters
                </button>

                <a asp-page="ListCourse" style="display: block; text-align: center; margin-top: 15px; font-size: 0.85rem; color: #b2bec3; text-decoration: none; font-weight: 600;">Reset Filters</a>
            </form>
        </aside>

        @* RIGHT: COURSE GRID *@
        <main>
            @if (Model.VM.Courses.Any())
            {
                <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(400px, 1fr)); gap: 25px;">
                    @foreach (var course in Model.VM.Courses)
                    {
                        @* ... Course Card Code (Kept exactly as you provided) ... *@
                        var statusInfo = GetStatusDetails(course.Status);
                        <div style="transition: all 0.3s ease; cursor: pointer; background: white; border-radius: 12px; overflow: hidden; box-shadow: 0 4px 15px rgba(0,0,0,0.05); display: flex; flex-direction: column; border: 1px solid #eee; height: 100%;"
                             onmouseover="this.style.transform='translateY(-8px)'; this.style.boxShadow='0 12px 25px rgba(72, 52, 212, 0.15)'; this.style.borderColor='#4834d4'; this.querySelector('.course-img-inner').style.transform='scale(1.08)';"
                             onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='0 4px 15px rgba(0,0,0,0.05)'; this.style.borderColor='#eee'; this.querySelector('.course-img-inner').style.transform='scale(1)';"
                             onclick="window.location.href='@Url.Page("DetailCourse", new { id = course.CourseID })'">
                            @* ... Card Internal Content ... *@
                            <div style="height: 180px; overflow: hidden; position: relative; background: #f0f2f5;">
                                @if (!string.IsNullOrEmpty(course.ThumbnailName))
                                {
                                    <img src="~/media/@course.ThumbnailName" class="course-img-inner" style="width: 100%; height: 100%; object-fit: cover; transition: transform 0.5s ease;" />
                                }
                                <div style="position: absolute; top: 12px; right: 12px; background: rgba(0,0,0,0.6); color: white; padding: 4px 10px; border-radius: 6px; font-size: 0.85rem; font-weight: 700; backdrop-filter: blur(4px);">
                                    @(course.Price > 0 ? course.Price?.ToString("N0") + " VND" : "Free")
                                </div>
                            </div>
                            <div style="padding: 20px; flex-grow: 1; display: flex; flex-direction: column;">
                                <div style="display: flex; align-items: center; gap: 6px; margin-bottom: 12px; flex-wrap: wrap;">
                                    <span style="font-size: 0.65rem; background: #ebf4ff; color: #4c51bf; padding: 3px 6px; border-radius: 4px; font-weight: 800; text-transform: uppercase;">@course.Subject?.Name</span>
                                    <span style="font-size: 0.65rem; background: #f3f4f6; color: #374151; padding: 3px 6px; border-radius: 4px; font-weight: 800; text-transform: uppercase;">@course.Grade?.Name</span>
                                    <span style="font-size: 0.7rem; padding: 3px 8px; border-radius: 4px; font-weight: 800; text-transform: uppercase; background: @statusInfo.bg; color: @statusInfo.text; border: 1px solid @statusInfo.text;">@statusInfo.label</span>
                                </div>
                                <h4 style="margin: 0 0 10px 0; color: #2d3436; font-size: 1.1rem; line-height: 1.4; font-weight: 700;">@course.Title</h4>
                                <p style="color: #636e72; font-size: 0.85rem; line-height: 1.5; margin-bottom: 20px; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">@course.Description</p>
                                <div style="margin-top: auto; display: flex; justify-content: space-between; align-items: center; padding-top: 15px; border-top: 1px solid #f0f2f5;">
                                    <div style="display: flex; align-items: center; gap: 8px;">
                                        <div style="width: 24px; height: 24px; background: #4834d4; color: white; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 0.65rem; font-weight: 800;">@course.Teacher?.Name?.Substring(0, 1)</div>
                                        <span style="font-size: 0.8rem; color: #2d3436; font-weight: 600;">@course.Teacher?.Name</span>
                                    </div>
                                    <span style="color: #4834d4; font-weight: 700; font-size: 0.8rem;">Details →</span>
                                </div>
                            </div>
                        </div>
                    }
                </div>

                @* PURPLE STYLE PAGINATION *@
                <div style="margin-top: 40px; display: flex; justify-content: center; gap: 8px; align-items: center;">

                    @* Previous Button *@
                    @if (Model.VM.CurrentPage > 1)
                    {
                        <a href="@Url.Page("ListCourse", new { title = Model.VM.Title, gradeName = Model.VM.GradeName, subjectName = Model.VM.SubjectName, page = Model.VM.CurrentPage - 1 })"
                           style="padding: 10px 15px; border-radius: 8px; border: 1px solid #dfe6e9; color: #2d3436; text-decoration: none; font-weight: 600; transition: 0.2s; background: white;"
                           onmouseover="this.style.borderColor='#4834d4'; this.style.color='#4834d4';" onmouseout="this.style.borderColor='#dfe6e9'; this.style.color='#2d3436';">
                            ← Prev
                        </a>
                    }

                    @* Page Numbers (Showing 5 around current) *@
                    @{
                        // Note: You might need to pass TotalPages from your service.
                        // If you don't have it yet, we show current and next.
                        int startPage = Math.Max(1, Model.VM.CurrentPage - 2);
                        int endPage = Model.VM.CurrentPage + 2;
                    }

                    @for (int p = startPage; p <= endPage; p++)
                    {
                        bool isCurrent = (p == Model.VM.CurrentPage);
                        <a href="@Url.Action("ListCourse", new { title = Model.VM.Title, gradeName = Model.VM.GradeName, subjectName = Model.VM.SubjectName, page = p })"
                           style="width: 40px; height: 40px; display: flex; align-items: center; justify-content: center; border-radius: 8px; text-decoration: none; font-weight: 700; transition: 0.3s;
                                                  @(isCurrent ? "background: #4834d4; color: white; box-shadow: 0 4px 10px rgba(72, 52, 212, 0.3);" : "background: white; border: 1px solid #dfe6e9; color: #2d3436;")"
                           onmouseover="@(isCurrent ? "" : "this.style.borderColor='#4834d4'; this.style.color='#4834d4'")"
                           onmouseout="@(isCurrent ? "" : "this.style.borderColor='#dfe6e9'; this.style.color='#2d3436'")">
                            @p
                        </a>
                    }

                    @* Next Button *@
                    <a href="@Url.Action("ListCourse", new { title = Model.VM.Title, gradeName = Model.VM.GradeName, subjectName = Model.VM.SubjectName, page = Model.VM.CurrentPage + 1 })"
                       style="padding: 10px 15px; border-radius: 8px; border: 1px solid #dfe6e9; color: #2d3436; text-decoration: none; font-weight: 600; transition: 0.2s; background: white;"
                       onmouseover="this.style.borderColor='#4834d4'; this.style.color='#4834d4';" onmouseout="this.style.borderColor='#dfe6e9'; this.style.color='#2d3436';">
                        Next →
                    </a>
                </div>
            }
            else
            {
                <div style="text-align: center; padding: 80px 20px; background: white; border-radius: 12px; border: 2px dashed #eee;">
                    <div style="font-size: 3rem; margin-bottom: 15px;">🔍</div>
                    <h3 style="color: #2d3436; margin: 0;">No courses found</h3>
                    <p style="color: #b2bec3;">Try adjusting your filters or search terms.</p>
                </div>
            }
        </main>
    </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>

<script>
    const connection = new signalR.HubConnectionBuilder()
        .withUrl("/courseHub")
        .withAutomaticReconnect()
        .build();

    // When a course is created
    connection.on("CourseCreated", () => {
        location.reload();
    });

    // When a course is updated
    connection.on("CourseReviewed", () => {
        location.reload();
    });

    // Start connection
    async function startSignalR() {
        try {
            await connection.start();
            console.log("SignalR connected");
        } catch (err) {
            console.error(err);
            setTimeout(startSignalR, 5000);
        }
    }

    startSignalR();
</script>