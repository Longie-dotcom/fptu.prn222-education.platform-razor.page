@page
@model PresentationLayer.Pages.Auth.VerifyEmailModel
@{
    ViewData["Title"] = "Verify Email";
}

<div style="display: flex; justify-content: center; align-items: center; padding-top: 100px;">
    <div style="background-color: #ffffff; padding: 40px; border-radius: 12px; box-shadow: 0 4px 20px rgba(0,0,0,0.08); width: 100%; max-width: 400px; border: 1px solid #eee;">

        <h3 style="text-align: center; margin-top: 10px; margin-bottom: 15px; color: #2d3436; font-size: 1.8rem; font-weight: 700;">Verify Email</h3>

        <p style="text-align: center; color: #636e72; font-size: 0.9rem; margin-bottom: 30px; line-height: 1.5;">
            Please enter the 6-digit verification code sent to your email.
        </p>

        @if (TempData["ToastMessage"] != null)
        {
            <div style="padding: 12px; margin-bottom: 20px; border-radius: 6px; font-size: 0.9rem; text-align: center;
                                color: @(TempData["ToastType"]?.ToString() == "danger" ? "#d63031" : "#00b894");
                                background-color: @(TempData["ToastType"]?.ToString() == "danger" ? "#fab1a033" : "#55efc433");
                                border: 1px solid @(TempData["ToastType"]?.ToString() == "danger" ? "#fab1a0" : "#55efc4");">
                @TempData["ToastMessage"]
            </div>
        }

        <form asp-action="VerifyEmail" method="post">
            @Html.AntiForgeryToken()

            <div style="margin-bottom: 40px;">
                <label style="display: block; margin-bottom: 8px; font-weight: 600; color: #636e72; font-size: 0.9rem;">Verification Code</label>
                <input type="text" name="otp" maxlength="6" required
                       placeholder="· · · · · ·"
                       style="width: 92%; padding: 4%; border: 1px solid #dfe6e9; border-radius: 6px; outline: none; font-size: 1.5rem; letter-spacing: 8px; text-align: center; transition: border-color 0.2s; color: #2d3436;"
                       onfocus="this.style.borderColor='#4834d4'" onblur="this.style.borderColor='#dfe6e9'" />
            </div>

            <button type="submit" style="width: 100%; padding: 4%; background-color: #4834d4; color: white; border: none; border-radius: 6px; font-size: 1rem; font-weight: 600; cursor: pointer; transition: background 0.3s ease;">
                Verify Account
            </button>
        </form>

        <div style="margin-top: 25px; text-align: center;">
            <span style="color: #b2bec3; font-size: 0.9rem;">Didn't get a code?</span>
            <a href="#" style="color: #4834d4; text-decoration: none; font-weight: 600; font-size: 0.9rem; margin-left: 5px;">Resend Code</a>
        </div>
    </div>
</div>