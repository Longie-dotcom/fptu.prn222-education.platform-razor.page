@page
@model PresentationLayer.Pages.Auth.RegisterModel
@{
    ViewData["Title"] = "Register";
}

<div style="display: flex; justify-content: center; align-items: center; padding: 100px 20px;">
    <div style="background-color: #ffffff; padding: 40px; border-radius: 12px; box-shadow: 0 4px 20px rgba(0,0,0,0.08); width: 100%; max-width: 700px; border: 1px solid #eee;">

        <h3 style="text-align: center; margin-top: 10px; margin-bottom: 30px; color: #2d3436; font-size: 1.8rem; font-weight: 700;">Create Account</h3>

        <form asp-action="Register" method="post" style="display: flex; gap: 30px; flex-wrap: wrap;">
            @Html.AntiForgeryToken()

            <div style="flex: 1; min-width: 250px;">
                <div style="margin-bottom: 20px;">
                    <label asp-for="Register.Email" style="display: block; margin-bottom: 6px; font-weight: 600; color: #636e72; font-size: 0.9rem;"></label>
                    <input asp-for="Register.Email" style="width: 100%; box-sizing: border-box; padding: 12px; border: 1px solid #dfe6e9; border-radius: 6px; outline: none; font-size: 1rem;"
                           onfocus="this.style.borderColor='#4834d4'" onblur="this.style.borderColor='#dfe6e9'" />
                </div>

                <div style="margin-bottom: 20px;">
                    <label asp-for="Register.Password" style="display: block; margin-bottom: 6px; font-weight: 600; color: #636e72; font-size: 0.9rem;"></label>
                    <input asp-for="Register.Password" type="password" style="width: 100%; box-sizing: border-box; padding: 12px; border: 1px solid #dfe6e9; border-radius: 6px; outline: none; font-size: 1rem;"
                           onfocus="this.style.borderColor='#4834d4'" onblur="this.style.borderColor='#dfe6e9'" />
                </div>

                <div style="margin-bottom: 20px;">
                    <label asp-for="Register.Name" style="display: block; margin-bottom: 6px; font-weight: 600; color: #636e72; font-size: 0.9rem;"></label>
                    <input asp-for="Register.Name" style="width: 100%; box-sizing: border-box; padding: 12px; border: 1px solid #dfe6e9; border-radius: 6px; outline: none; font-size: 1rem;"
                           onfocus="this.style.borderColor='#4834d4'" onblur="this.style.borderColor='#dfe6e9'" />
                </div>
            </div>

            <div style="flex: 1; min-width: 250px; display: flex; flex-direction: column; justify-content: space-between;">
                <div>
                    <div style="margin-bottom: 20px;">
                        <label asp-for="Register.Phone" style="display: block; margin-bottom: 6px; font-weight: 600; color: #636e72; font-size: 0.9rem;"></label>
                        <input asp-for="Register.Phone" style="width: 100%; box-sizing: border-box; padding: 12px; border: 1px solid #dfe6e9; border-radius: 6px; outline: none; font-size: 1rem;"
                               onfocus="this.style.borderColor='#4834d4'" onblur="this.style.borderColor='#dfe6e9'" />
                    </div>

                    <div style="margin-bottom: 20px;">
                        <label asp-for="Register.Role" style="display: block; margin-bottom: 6px; font-weight: 600; color: #636e72; font-size: 0.9rem;">Register as</label>
                        <select asp-for="Register.Role" style="width: 100%; box-sizing: border-box; padding: 12px; border: 1px solid #dfe6e9; border-radius: 6px; outline: none; font-size: 1rem; background-color: white; cursor: pointer;">
                            <option value="1">Student</option>
                            <option value="2">Teacher</option>
                        </select>
                    </div>
                </div>

                <div style="margin-top: auto; padding-bottom: 20px;">
                    <button type="submit" style="width: 100%; background-color: #00b894; color: white; border: none; padding: 14px; border-radius: 6px; font-size: 1rem; font-weight: 600; cursor: pointer; transition: background 0.3s ease;">
                        Register
                    </button>
                </div>
            </div>
        </form>

        <div style="margin-top: 20px; text-align: center;">
            <a asp-action="Login" style="color: #636e72; text-decoration: none; font-size: 0.9rem; border-bottom: 1px solid #dfe6e9; padding-bottom: 2px;">
                Already have an account? Login
            </a>
        </div>
    </div>
</div>