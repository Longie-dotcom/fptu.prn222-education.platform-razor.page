@page
@model PresentationLayer.Pages.Auth.LoginModel
@{
    ViewData["Title"] = "Login";
}

<div style="display: flex; justify-content: center; align-items: center; padding-top: 100px;">
    <div style="background-color: #ffffff; padding: 40px; border-radius: 12px; box-shadow: 0 4px 20px rgba(0,0,0,0.08); width: 100%; max-width: 400px; border: 1px solid #eee;">

        <h3 style="text-align: center; margin-top: 10px; margin-bottom: 30px; color: #2d3436; font-size: 1.8rem; font-weight: 700;">Login</h3>

        <form method="post">
            @Html.AntiForgeryToken()

            <div style="margin-bottom: 20px;">
                <label asp-for="Login.Email" style="display: block; margin-bottom: 8px; font-weight: 600; color: #636e72; font-size: 0.9rem;"></label>
                <input asp-for="Login.Email" style="width: 92%; padding: 4%; border: 1px solid #dfe6e9; border-radius: 6px; outline: none; font-size: 1rem; transition: border-color 0.2s;"
                       onfocus="this.style.borderColor='#4834d4'" onblur="this.style.borderColor='#dfe6e9'" />
            </div>

            <div style="margin-bottom: 40px;">
                <label asp-for="Login.Password" style="display: block; margin-bottom: 8px; font-weight: 600; color: #636e72; font-size: 0.9rem;"></label>
                <input asp-for="Login.Password" type="password" style="width: 92%; padding: 4%; border: 1px solid #dfe6e9; border-radius: 6px; outline: none; font-size: 1rem; transition: border-color 0.2s;"
                       onfocus="this.style.borderColor='#4834d4'" onblur="this.style.borderColor='#dfe6e9'" />
            </div>

            <button type="submit" style="width: 100%; padding: 4%; background-color: #4834d4; color: white; border: none; border-radius: 6px; font-size: 1rem; font-weight: 600; cursor: pointer; transition: background 0.3s ease;">
                Login
            </button>
        </form>

        <div style="margin-top: 20px; text-align: center;">
            <span style="color: #b2bec3; font-size: 0.9rem;">Don't have an account?</span>
            <a asp-page="Register" style="color: #4834d4; text-decoration: none; font-weight: 600; font-size: 0.9rem; margin-left: 5px;">Create account</a>
        </div>
    </div>
</div>