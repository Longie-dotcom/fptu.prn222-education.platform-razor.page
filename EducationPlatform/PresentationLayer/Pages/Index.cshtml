@page
@model IndexModel

@{
    ViewData["Title"] = "Home";
}

<main>
    <section class="hero" style="margin-bottom: 40px; border-radius: 10px">
        <div class="hero-inner container-lg">
            <div class="hero-text">
                <h1 class="hero-title">Next level skills.<br />Learn from the best.</h1>
                <p class="hero-subtitle">
                    Interactive courses, lessons and practice quizzes — built for learners and teachers.
                </p>

                <div class="hero-ctas">
                    <a class="btn-primary" asp-page="/Course/ListCourse">Explore Courses</a>
                    <a class="btn-secondary" asp-page="/Course/ListCourse">Browse Subjects</a>
                </div>

                <div class="hero-meta">
                    <span class="price-badge">$80/year</span>
                    <span class="company-list">From Microsoft, Google, IBM & Meta</span>
                </div>
            </div>

            <div class="hero-visual">
                <svg class="hero-svg" viewBox="0 0 280 280" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <defs>
                        <linearGradient id="grad1" x1="0%" y1="0%" x2="100%" y2="100%">
                            <stop offset="0%" style="stop-color:#5a8cff;stop-opacity:1" />
                            <stop offset="100%" style="stop-color:#3f6fe6;stop-opacity:1" />
                        </linearGradient>
                    </defs>

                    <rect x="20" y="30" width="240" height="220" rx="16" fill="url(#grad1)" />

                    <circle cx="60" cy="80" r="28" fill="#fff" opacity="0.95" />
                    <rect x="100" y="60" width="140" height="22" rx="5" fill="#fff" opacity="0.9" />
                    <rect x="100" y="92" width="100" height="14" rx="4" fill="#fff" opacity="0.85" />
                    <rect x="100" y="114" width="80" height="12" rx="4" fill="#fff" opacity="0.8" />

                    <rect x="30" y="180" width="70" height="16" rx="4" fill="#fff" opacity="0.75" />
                    <rect x="110" y="180" width="70" height="16" rx="4" fill="#fff" opacity="0.75" />
                    <rect x="190" y="180" width="60" height="16" rx="4" fill="#fff" opacity="0.75" />
                </svg>
            </div>
        </div>
    </section>

    <section class="partners container-lg" style="border-radius: 10px">
        <h2 class="partners-title">Learn from 350+ top institutions</h2>

        <div class="partner-rows">
            <div class="partner-logo">ILLINOIS</div>
            <div class="partner-logo">DUKE</div>
            <div class="partner-logo">GOOGLE</div>
            <div class="partner-logo">MICHIGAN</div>
            <div class="partner-logo">IBM</div>
            <div class="partner-logo">VANDERBILT</div>
            <div class="partner-logo">JOHNS HOPKINS</div>
        </div>
    </section>

    <section class="features container-lg">
        <h2 class="features-title">Why choose EduPlatform?</h2>

        <div class="features-grid">
            <div class="feature-card">
                <div class="feature-icon">📹</div>
                <h5>Practical Lessons</h5>
                <p>Hands-on video lessons with progress tracking and quizzes.</p>
            </div>

            <div class="feature-card">
                <div class="feature-icon">👨‍🏫</div>
                <h5>Expert Teachers</h5>
                <p>Courses created and reviewed by experienced instructors.</p>
            </div>

            <div class="feature-card">
                <div class="feature-icon">⏱️</div>
                <h5>Flexible Learning</h5>
                <p>Learn at your own pace with saved progress and badges.</p>
            </div>
        </div>
    </section>
</main>